# PostgreSQL connection (backend reads these via process.env)
# When using Docker Compose, keep DB_HOST set to the postgres service name: db
DB_HOST=db
DB_PORT=5432
DB_USER=libbook_user
DB_PASSWORD=changeme
DB_NAME=libbook

# Backend
PORT=3000

# Frontend build-time API URL
# The frontend app will request the backend via /api/books and nginx proxies /api/ to backend.
VITE_API_URL=/api/books
